# Copy to `.env.local` and fill in. Keep this file in sync with lib/env.ts.
# Server-only secrets have no prefix. Browser-exposed vars MUST start NEXT_PUBLIC_.

NODE_ENV=development

# --- MongoDB ---
# Reuse the same cluster you use for form-builder-portal; just change the DB name.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=treadhouse

# --- Better Auth ---
# Generate a secret:  npx @better-auth/cli@latest secret   (or: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Email (optional) ---
# Leave blank in dev — OTP codes are printed to the terminal instead of emailed.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# --- Cron (saved-search alerts) ---
# Shared secret for /api/cron/* (sent as the `x-cron-secret` header). When unset,
# the cron endpoints are disabled (503). Generate: openssl rand -hex 24
# CRON_SECRET=

# --- AI assistant (OpenRouter + Vercel AI SDK) ---
# Get a key at https://openrouter.ai/keys. When unset, the assistant API
# responds 503 and the chat widget hides itself (same pattern as S3/SendGrid).
# OPENROUTER_API_KEY=
# Optional overrides (defaults live in lib/env.ts):
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_FALLBACK_MODEL=anthropic/claude-3.5-haiku

# --- Voice (speech-to-text dictation + spoken replies via OpenAI) ---
# The voice ears (STT) + mouth (TTS) run on OpenAI's audio API with their own
# key; the assistant brain still runs on OpenRouter above. Get a key at
# https://platform.openai.com/api-keys. Voice routes respond 503 (and the mic
# stays hidden/erroring) until OPENAI_API_KEY is set.
# OPENAI_API_KEY=
# Optional overrides (defaults live in lib/env.ts):
# STT: gpt-4o-transcribe (default) | gpt-4o-mini-transcribe | whisper-1
# VOICE_STT_MODEL=gpt-4o-transcribe
# TTS: gpt-4o-mini-tts (default, steerable) | tts-1 | tts-1-hd
# Voices: alloy, ash, ballad, coral, echo, fable, nova, onyx, sage, shimmer, verse
# VOICE_TTS_MODEL=gpt-4o-mini-tts
# VOICE_TTS_VOICE=coral

# --- Browser-exposed ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
